{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": false,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": [
    "src/index.ts",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/lib/**/*.ts",
    "src/lib/**/*.tsx",
    "src/subpaths/**/*.ts"
  ],
  "exclude": [
    "src/playground/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test/**",
    "src/main.tsx",
    "src/App.tsx"
  ]
}
